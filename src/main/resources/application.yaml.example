# application.yaml.example
spring:
  datasource:
    url: jdbc:mysql://localhost:3306/smart_inventory?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
    username: root
    password:    # 비밀번호 입력 후 application.yaml로 복사해서 사용
  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
server:
  port: 8080